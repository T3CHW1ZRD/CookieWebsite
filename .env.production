# Production build configuration for the Lailah's Cookies site.
# Vite picks these up automatically when running `npm run build`.

# Re-enable the owner dashboard at /#/admin so Lailah can edit content.
VITE_ENABLE_ADMIN=true

# The GitHub repo the dashboard's Publish button commits to.
# A fine-grained PAT scoped to ONLY this repo (Contents: read+write) is
# the only thing the dashboard ever talks to.
VITE_GH_OWNER=T3CHW1ZRD
VITE_GH_REPO=CookieWebsite
VITE_GH_BRANCH=main
